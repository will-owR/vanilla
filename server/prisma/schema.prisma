generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prompt {
  id             Int        @id @default(autoincrement())
  prompt         String
  normalizedText String?
  normalizedHash String?    @unique
  createdAt      DateTime   @default(now())
  aiResults      AIResult[]
}

model AIResult {
  id         Int         @id @default(autoincrement())
  promptId   Int
  result     Json
  createdAt  DateTime    @default(now())
  prompt     Prompt      @relation(fields: [promptId], references: [id])
  overrides  Override[]
  pdfExports PDFExport[]
}

model Override {
  id         Int      @id @default(autoincrement())
  aiResultId Int
  override   Json
  createdAt  DateTime @default(now())
  aiResult   AIResult @relation(fields: [aiResultId], references: [id])
}

model PDFExport {
  id         Int      @id @default(autoincrement())
  aiResultId Int
  filePath   String
  createdAt  DateTime @default(now())
  aiResult   AIResult @relation(fields: [aiResultId], references: [id])
}

model Result {
  id          Int         @id @default(autoincrement())
  resultId    String      @unique @db.Uuid
  outEnvelope Json
  mode        String      @db.VarChar(50)
  promptId    Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  exportJobs  ExportJob[]

  @@index([resultId])
  @@index([createdAt])
  @@map("results")
}

model ExportJob {
  id           Int       @id @default(autoincrement())
  jobId        String    @unique @db.Uuid
  resultId     String    @db.Uuid
  status       String    @default("queued") @db.VarChar(50)
  progress     Int       @default(0)
  pdfPath      String?   @db.VarChar(500)
  errorMessage String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
  result       Result    @relation(fields: [resultId], references: [resultId])

  @@index([jobId])
  @@index([resultId])
  @@index([status])
  @@index([createdAt])
  @@map("export_jobs")
}

model SvgLibrary {
  id               String    @id @default(uuid()) @db.Uuid
  svg_data         String
  png_url          String?   @db.VarChar(512)
  metadata         Json
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt
  deleted_at       DateTime?
  created_by       String?   @db.VarChar(255)
  file_size_bytes  Int?
  render_time_ms   Int?

  @@index([metadata])
  @@index([created_at])
  @@map("svg_library")
}

model Calendar {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}

// Metrics models for observability (Phase 4)
model MetricsSession {
  id           Int      @id @default(autoincrement())
  sessionId    String   @unique
  startTime    DateTime
  endTime      DateTime?
  ebookMetadata Json
  summary      Json?
  createdAt    DateTime @default(now())
  events       MetricsEvent[]

  @@index([sessionId])
  @@index([createdAt])
}

model MetricsEvent {
  id        Int      @id @default(autoincrement())
  sessionId String
  type      String   @db.VarChar(100)
  payload   Json
  timestamp DateTime @default(now())

  session   MetricsSession @relation(fields: [sessionId], references: [sessionId])

  @@index([sessionId])
  @@index([timestamp])
}
