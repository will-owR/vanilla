# Local development env file - DO NOT COMMIT your real secrets here.
# Copy this to .env and set your own values.

# Dev token used by the dev-only auth middleware in server/index.js
# Note: the dev auth middleware is only enabled when NODE_ENV=development.
# Tests (NODE_ENV=test) will not be blocked by this token.
DEV_AUTH_TOKEN=yourtoken123

# Optional: override default port
# PORT=3001

# Optional: skip Puppeteer in CI/tests
# SKIP_PUPPETEER=true

# Rate-limiter configuration (inter-request pacing for Gemini API)
# Minimum milliseconds between consecutive API calls to prevent burst rate overload
# Default: 1000ms (1 second)
# Tune for testing: 0 (no delay), 250, 500, 1000, 2000
# RATE_LIMIT_MIN_DELAY_MS=1000
