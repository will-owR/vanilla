# Example environment variables required by the devcontainer and server
# Copy this to .env and fill with real values for your environment.

# Postgres (used by docker-compose dev DB)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=aether_dev

# AI provider (replace with real keys/URLs when available)
GEMINI_API_URL=
GEMINI_API_KEY=

# Puppeteer / Chrome
# If Chrome is installed in the devcontainer/Dockerfile this should work:
CHROME_PATH=/usr/bin/google-chrome-stable
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# PAT - Personal access tokens (classic)
GITHUB_TOKEN=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

# Debug/dev toggles
DISABLE_RATE_LIMIT=1

# If using Postgres with Prisma, set DATABASE_URL in the format:
# postgresql://user:password@host:5432/dbname
# Example (for local docker-compose Postgres):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/aether_dev
